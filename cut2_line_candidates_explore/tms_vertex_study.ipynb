{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# TMS Vertex Reconstruction & Validation\n",
    "\n",
    "This notebook focuses on **vertex reconstruction inside the TMS volume** using reconstructed track information, and validates the reconstructed vertices against the true vertex coordinates in `Truth_Info`.\n",
    "\n",
    "### TMS Volume Bounds (in mm):\n",
    "- **X:** $[-3730, +3730]$\n",
    "- **Y:** $[-3100, +400]$\n",
    "- **Z:** $[11124, 18544]$\n",
    "\n",
    "### Validation Modes:\n",
    "1. **Truth-assisted grouping (Mode A):** Reco tracks are grouped by their true vertex ID (`RecoTrackPrimaryParticleVtxId`), a vertex is reconstructed for each group, and compared to the true vertex coordinates.\n",
    "2. **Reco-only grouping (Mode B):** Reco tracks are clustered using only geometric constraints (pairwise start point distance < 400 mm and DCA < 150 mm). The reconstructed vertices are compared to the nearest true vertex in the TMS."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import uproot\n",
    "import awkward as ak\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "plt.rcParams.update({\n",
    "    \"figure.figsize\": (8, 5),\n",
    "    \"axes.titlesize\": 14,\n",
    "    \"axes.labelsize\": 12,\n",
    "    \"figure.dpi\": 100,\n",
    "})\n",
    "\n",
    "print(\"Imports successful! ✓\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data & Convert to Fast Formats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "file_path = Path(\"../Cut2.root\")\n",
    "f = uproot.open(file_path)\n",
    "t_rc = f[\"Reco_Tree;2\"]\n",
    "t_tr = f[\"Truth_Info;2\"]\n",
    "\n",
    "rc_arr = t_rc.arrays([\"TrackHitPos\", \"nTracks\"])\n",
    "tr_arr = t_tr.arrays([\"TrueVtxX\", \"TrueVtxY\", \"TrueVtxZ\", \"TrueVtxID\", \"RecoTrackPrimaryParticleVtxId\"])\n",
    "\n",
    "# Convert awkward to standard python lists to speed up scalar indexing inside loops\n",
    "true_vtx_x = [v.tolist() for v in tr_arr[\"TrueVtxX\"]]\n",
    "true_vtx_y = [v.tolist() for v in tr_arr[\"TrueVtxY\"]]\n",
    "true_vtx_z = [v.tolist() for v in tr_arr[\"TrueVtxZ\"]]\n",
    "true_vtx_id = [v.tolist() for v in tr_arr[\"TrueVtxID\"]]\n",
    "track_vtx_ids = [v.tolist() for v in tr_arr[\"RecoTrackPrimaryParticleVtxId\"]]\n",
    "n_tracks_list = rc_arr[\"nTracks\"].tolist()\n",
    "\n",
    "print(f\"Loaded {len(rc_arr)} events.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Reconstruction Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "TMS_X_MIN, TMS_X_MAX = -3730.0, 3730.0\n",
    "TMS_Y_MIN, TMS_Y_MAX = -3100.0, 400.0\n",
    "TMS_Z_MIN, TMS_Z_MAX = 11124.0, 18544.0\n",
    "\n",
    "def is_inside_tms(x, y, z):\n",
    "    return (TMS_X_MIN <= x <= TMS_X_MAX) and \\\n",
    "           (TMS_Y_MIN <= y <= TMS_Y_MAX) and \\\n",
    "           (TMS_Z_MIN <= z <= TMS_Z_MAX)\n",
    "\n",
    "def fit_3d_line(hits):\n",
    "    mean = np.mean(hits, axis=0)\n",
    "    centered = hits - mean\n",
    "    cov = np.cov(centered, rowvar=False)\n",
    "    if cov.ndim < 2:\n",
    "        return mean, np.array([0.0, 0.0, 1.0]), 0.0\n",
    "    eigenvalues, eigenvectors = np.linalg.eigh(cov)\n",
    "    direction = eigenvectors[:, np.argmax(eigenvalues)]\n",
    "    \n",
    "    diff = centered\n",
    "    proj = diff - np.outer(diff @ direction, direction)\n",
    "    residuals = np.sum(proj**2, axis=1)\n",
    "    mean_residual = np.mean(residuals)\n",
    "    return mean, direction, mean_residual\n",
    "\n",
    "def get_dca_line_to_line(p1, d1, p2, d2):\n",
    "    n = np.cross(d1, d2)\n",
    "    n_len = np.linalg.norm(n)\n",
    "    if n_len < 1e-6:\n",
    "        return np.linalg.norm(np.cross(p2 - p1, d1)), p1, p2\n",
    "    dca = np.abs((p2 - p1) @ n) / n_len\n",
    "    \n",
    "    a = d1 @ d1\n",
    "    b = d1 @ d2\n",
    "    c = d2 @ d2\n",
    "    d = (p2 - p1) @ d1\n",
    "    e = (p2 - p1) @ d2\n",
    "    \n",
    "    denom = a * c - b * b\n",
    "    if np.abs(denom) < 1e-6:\n",
    "        return dca, p1, p2\n",
    "        \n",
    "    s = (c * d - b * e) / denom\n",
    "    t = (b * d - a * e) / denom\n",
    "    pt1 = p1 + s * d1\n",
    "    pt2 = p2 + t * d2\n",
    "    return dca, pt1, pt2\n",
    "\n",
    "def reconstruct_vertex(lines):\n",
    "    if len(lines) == 0:\n",
    "        return None\n",
    "    if len(lines) == 1:\n",
    "        return lines[0][0]\n",
    "    A = np.zeros((3, 3))\n",
    "    b = np.zeros(3)\n",
    "    for p, d, _ in lines:\n",
    "        proj = np.eye(3) - np.outer(d, d)\n",
    "        A += proj\n",
    "        b += proj @ p\n",
    "    try:\n",
    "        return np.linalg.solve(A, b)\n",
    "    except np.linalg.LinAlgError:\n",
    "        return np.mean([p for p, d, _ in lines], axis=0)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Run Validation Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "records = []\n",
    "\n",
    "for event_id in range(len(rc_arr)):\n",
    "    n_tracks = n_tracks_list[event_id]\n",
    "    if n_tracks < 1:\n",
    "        continue\n",
    "        \n",
    "    vtx_ids_all = true_vtx_id[event_id]\n",
    "    track_vtx_ids = track_vtx_ids_list = tr_arr[\"RecoTrackPrimaryParticleVtxId\"][event_id].tolist()\n",
    "    \n",
    "    # Select true TMS vertices\n",
    "    tms_vtxs = {}\n",
    "    for idx, vtx_id in enumerate(vtx_ids_all):\n",
    "        tx = true_vtx_x[event_id][idx]\n",
    "        ty = true_vtx_y[event_id][idx]\n",
    "        tz = true_vtx_z[event_id][idx]\n",
    "        if is_inside_tms(tx, ty, tz):\n",
    "            tms_vtxs[vtx_id] = np.array([tx, ty, tz])\n",
    "            \n",
    "    # Fit reco tracks\n",
    "    lines = []\n",
    "    track_starts = []\n",
    "    \n",
    "    for track_idx in range(n_tracks):\n",
    "        hits = ak.to_numpy(rc_arr[\"TrackHitPos\"][event_id][track_idx])\n",
    "        mask = hits[:, 0] > -9e8\n",
    "        actual_hits = hits[mask]\n",
    "        \n",
    "        if len(actual_hits) >= 2:\n",
    "            p, d, resid = fit_3d_line(actual_hits)\n",
    "            lines.append((p, d, resid))\n",
    "            track_starts.append(actual_hits[np.argmin(actual_hits[:, 2])])\n",
    "            \n",
    "    if len(lines) == 0:\n",
    "        continue\n("
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "    # MODE A: Truth-Assisted Grouping\n",
    "    truth_groups = {}\n",
    "    for idx, tv_id in enumerate(track_vtx_ids):\n",
    "        if tv_id in tms_vtxs and idx < len(lines):\n",
    "            if tv_id not in truth_groups:\n",
    "                truth_groups[tv_id] = []\n",
    "            truth_groups[tv_id].append(idx)\n",
    "            \n",
    "    for tv_id, track_indices in truth_groups.items():\n",
    "        sub_lines = [lines[i] for i in track_indices]\n",
    "        if len(sub_lines) == 1:\n",
    "            reco_vtx = track_starts[track_indices[0]]\n",
    "        else:\n",
    "            reco_vtx = reconstruct_vertex(sub_lines)\n",
    "            \n",
    "        true_vtx = tms_vtxs[tv_id]\n",
    "        dx = reco_vtx[0] - true_vtx[0]\n",
    "        dy = reco_vtx[1] - true_vtx[1]\n",
    "        dz = reco_vtx[2] - true_vtx[2]\n",
    "        dr = np.linalg.norm(reco_vtx - true_vtx)\n",
    "        \n",
    "        records.append({\n",
    "            \"event_id\": event_id,\n",
    "            \"true_vtx_id\": tv_id,\n",
    "            \"reco_vtx_x\": reco_vtx[0], \"reco_vtx_y\": reco_vtx[1], \"reco_vtx_z\": reco_vtx[2],\n",
    "            \"true_vtx_x\": true_vtx[0], \"true_vtx_y\": true_vtx[1], \"true_vtx_z\": true_vtx[2],\n",
    "            \"dx\": dx, \"dy\": dy, \"dz\": dz, \"dr\": dr,\n",
    "            \"n_tracks_in_vertex\": len(track_indices),\n",
    "            \"grouping_mode\": \"Truth-assisted\"\n",
    "        })\n("
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "    # MODE B: Reco-Only Grouping\n",
    "    n_lines = len(lines)\n",
    "    adj = np.eye(n_lines, dtype=bool)\n",
    "    \n",
    "    for i in range(n_lines):\n",
    "        for j in range(i+1, n_lines):\n",
    "            dca, _, _ = get_dca_line_to_line(lines[i][0], lines[i][1], lines[j][0], lines[j][1])\n",
    "            start_dist = np.linalg.norm(track_starts[i] - track_starts[j])\n",
    "            if dca < 150.0 and start_dist < 400.0:\n",
    "                adj[i, j] = adj[j, i] = True\n",
    "                \n",
    "    visited = np.zeros(n_lines, dtype=bool)\n",
    "    clusters = []\n",
    "    for i in range(n_lines):\n",
    "        if not visited[i]:\n",
    "            comp = []\n",
    "            queue = [i]\n",
    "            visited[i] = True\n",
    "            while queue:\n",
    "                curr = queue.pop(0)\n",
    "                comp.append(curr)\n",
    "                for neighbor in range(n_lines):\n",
    "                    if adj[curr, neighbor] and not visited[neighbor]:\n",
    "                        visited[neighbor] = True\n",
    "                        queue.append(neighbor)\n",
    "            clusters.append(comp)\n",
    "            \n",
    "    for comp in clusters:\n",
    "        sub_lines = [lines[i] for i in comp]\n",
    "        if len(sub_lines) == 1:\n",
    "            reco_vtx = track_starts[comp[0]]\n",
    "        else:\n",
    "            reco_vtx = reconstruct_vertex(sub_lines)\n",
    "            \n",
    "        if len(tms_vtxs) == 0:\n",
    "            continue\n",
    "            \n",
    "        nearest_tv_id = None\n",
    "        min_dist = float('inf')\n",
    "        for tv_id, tv_pos in tms_vtxs.items():\n",
    "            dist = np.linalg.norm(reco_vtx - tv_pos)\n",
    "            if dist < min_dist:\n",
    "                min_dist = dist\n",
    "                nearest_tv_id = tv_id\n",
    "                \n",
    "        if nearest_tv_id is not None:\n",
    "            true_vtx = tms_vtxs[nearest_tv_id]\n",
    "            records.append({\n",
    "                \"event_id\": event_id,\n",
    "                \"true_vtx_id\": nearest_tv_id,\n",
    "                \"reco_vtx_x\": reco_vtx[0], \"reco_vtx_y\": reco_vtx[1], \"reco_vtx_z\": reco_vtx[2],\n",
    "                \"true_vtx_x\": true_vtx[0], \"true_vtx_y\": true_vtx[1], \"true_vtx_z\": true_vtx[2],\n",
    "                \"dx\": reco_vtx[0] - true_vtx[0], \"dy\": reco_vtx[1] - true_vtx[1], \"dz\": reco_vtx[2] - true_vtx[2],\n",
    "                \"dr\": min_dist,\n",
    "                \"n_tracks_in_vertex\": len(comp),\n",
    "                \"grouping_mode\": \"Reco-only\"\n",
    "            })\n("\
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.DataFrame(records)\n",
    "df.to_csv(\"tms_vertex_validation.csv\", index=False)\n",
    "print(f\"Validation complete. Saved {len(df)} records to tms_vertex_validation.csv.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Evaluate Statistical Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "for mode in [\"Truth-assisted\", \"Reco-only\"]:\n",
    "    sub_df = df[df[\"grouping_mode\"] == mode]\n",
    "    print(f\"\\n=========================================\")\n",
    "    print(f\"Grouping Mode: {mode} (N={len(sub_df)})\")\n",
    "    print(f\"=========================================\")\n",
    "    print(\"Mean +/- Std:\")\n",
    "    print(f\"  dx: {np.mean(sub_df['dx']):.2f} +/- {np.std(sub_df['dx']):.2f} mm\")\n",
    "    print(f"  dy: {np.mean(sub_df['dy']):.2f} +/- {np.std(sub_df['dy']):.2f} mm\")\n",
    "    print(f\"  dz: {np.mean(sub_df['dz']):.2f} +/- {np.std(sub_df['dz']):.2f} mm\")\n",
    "    print(f\"  dr: {np.mean(sub_df['dr']):.2f} +/- {np.std(sub_df['dr']):.2f} mm\")\n",
    "    \n",
    "    print(\"\\nMedian Absolute Residuals:\")\n",
    "    print(f\"  dx: {np.median(np.abs(sub_df['dx'])):.2f} mm\")\n",
    "    print(f\"  dy: {np.median(np.abs(sub_df['dy'])):.2f} mm\")\n",
    "    print(f\"  dz: {np.median(np.abs(sub_df['dz'])):.2f} mm\")\n",
    "    print(f\"  dr: {np.median(sub_df['dr']):.2f} mm\")\n",
    "    \n",
    "    print(\"\\nFraction of reconstructed vertices within:\")\n",
    "    for d in [50, 100, 200, 500]:\n",
    "        frac = np.mean(sub_df[\"dr\"] < d) * 100.0\n",
    "        print(f\"  {d:3d} mm: {frac:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Reco-vs-True Scatter Plots"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "coords = [(\"true_vtx_x\", \"reco_vtx_x\", \"X (mm)\"), \n",
    "          (\"true_vtx_y\", \"reco_vtx_y\", \"Y (mm)\"), \n",
    "          (\"true_vtx_z\", \"reco_vtx_z\", \"Z (mm)\")]\n",
    "\n",
    "reco_only_df = df[df[\"grouping_mode\"] == \"Reco-only\"]\n",
    "\n",
    "for i, (true_c, reco_c, label) in enumerate(coords):\n",
    "    ax = axes[i]\n",
    "    ax.scatter(reco_only_df[true_c], reco_only_df[reco_c], alpha=0.4, color='forestgreen', s=10)\n",
    "    # Draw identity line\n",
    "    lims = [min(ax.get_xlim()[0], ax.get_ylim()[0]), max(ax.get_xlim()[1], ax.get_ylim()[1])]\n",
    "    ax.plot(lims, lims, '--', color='red', alpha=0.7)\n",
    "    ax.set_title(f\"Reco vs. True {label}\")\n",
    "    ax.set_xlabel(f\"True {label}\")\n",
    "    ax.set_ylabel(f\"Reco {label}\")\n",
    "    ax.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Performance vs. Number of Tracks at Vertex"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Group by n_tracks_in_vertex and calculate median dr\n",
    "track_stats = reco_only_df.groupby(\"n_tracks_in_vertex\")[\"dr\"].agg([\"count\", \"mean\", \"median\"])\n",
    "print(\"Vertex Resolution vs. Track Multiplicity:\")\n",
    "print(track_stats)\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.bar(track_stats.index.astype(str), track_stats[\"median\"], color='teal', edgecolor='black', width=0.5)\n",
    "plt.xlabel(\"Number of Tracks in Reconstructed Vertex\")\n",
    "plt.ylabel(\"Median Residual $dr$ (mm)\")\n",
    "plt.title(\"Vertex Resolution vs. Track Multiplicity\")\n",
    "plt.grid(axis='y', linestyle=':', alpha=0.6)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. 3D Event Display of Reconstructed and True Vertices"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig = plt.figure(figsize=(10, 8))\n",
    "ax = fig.add_subplot(111, projection='3d')\n",
    "\n",
    "# Sample 100 random vertices for clean visual separation\n",
    "sample_df = reco_only_df.sample(min(100, len(reco_only_df)), random_state=42)\n",
    "\n",
    "ax.scatter(sample_df[\"true_vtx_z\"], sample_df[\"true_vtx_x\"], sample_df[\"true_vtx_y\"], color='black', marker='o', s=20, label='True Vertices')\n",
    "ax.scatter(sample_df[\"reco_vtx_z\"], sample_df[\"reco_vtx_x\"], sample_df[\"reco_vtx_y\"], color='red', marker='x', s=25, label='Reco Vertices')\n",
    "\n",
    "# Connect matched pairs with lines\n",
    "for idx, row in sample_df.iterrows():\n",
    "    ax.plot([row[\"true_vtx_z\"], row[\"reco_vtx_z\"]], \n",
    "            [row[\"true_vtx_x\"], row[\"reco_vtx_x\"]], \n",
    "            [row[\"true_vtx_y\"], row[\"reco_vtx_y\"]], color='gray', alpha=0.3)\n",
    "\n",
    "ax.set_xlabel('Z (mm)')\n",
    "ax.set_ylabel('X (mm)')\n",
    "ax.set_zlabel('Y (mm)')\n",
    "ax.set_title(\"3D Reco vs. True Vertices inside TMS\")\n",
    "ax.legend()\n",
    "plt.show()"
   ]
  }
 ],
